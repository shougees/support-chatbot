<% content_for :title, "Support Chatbot" %>

<section class="mx-auto flex w-full max-w-3xl flex-col gap-6 rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
  <div class="space-y-3">
    <p class="text-sm font-medium uppercase tracking-wide text-emerald-700">Ecommerce support</p>
    <h1 class="text-4xl font-semibold tracking-normal text-stone-950 sm:text-5xl">Support Chatbot</h1>
    <p class="max-w-2xl text-base leading-7 text-stone-600">Start a support conversation for an order, return, refund, missing item, damaged item, or account question.</p>
  </div>

  <div>
    <%= button_to "Start support conversation", conversations_path, method: :post, class: "rounded-md bg-stone-950 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-stone-800" %>
  </div>
</section>
