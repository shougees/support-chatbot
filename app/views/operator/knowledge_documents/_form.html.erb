<%= form_with model: [ :operator, knowledge_document ], class: "space-y-5" do |form| %>
  <% if knowledge_document.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% knowledge_document.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "text-sm font-medium text-stone-900" %>
    <%= form.text_field :title, class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <%= form.label :category, class: "text-sm font-medium text-stone-900" %>
      <%= form.text_field :category, class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= form.label :source_type, class: "text-sm font-medium text-stone-900" %>
      <%= form.select :source_type, KnowledgeDocument::SOURCE_TYPES.map { |source_type| [ source_type.humanize, source_type ] }, {}, class: "mt-2 block w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>
  </div>

  <div>
    <%= form.label :source_identifier, class: "text-sm font-medium text-stone-900" %>
    <%= form.text_field :source_identifier, class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div>
    <%= form.label :body, class: "text-sm font-medium text-stone-900" %>
    <%= form.text_area :body, rows: 12, class: "mt-2 block w-full resize-y rounded-md border border-stone-300 px-3 py-2 text-sm leading-6 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div>
    <%= form.label :status, class: "text-sm font-medium text-stone-900" %>
    <%= form.select :status, KnowledgeDocument::STATUSES.map { |status| [ status.humanize, status ] }, {}, class: "mt-2 block w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div class="flex flex-wrap items-center justify-end gap-3 border-t border-stone-200 pt-5">
    <%= link_to "Cancel", operator_knowledge_documents_path, class: "text-sm font-semibold text-stone-600 hover:text-stone-950" %>
    <%= form.submit class: "rounded-md bg-stone-950 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-stone-800" %>
  </div>
<% end %>
