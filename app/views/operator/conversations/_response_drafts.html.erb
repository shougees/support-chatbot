<div id="<%= dom_id(conversation, :operator_response_drafts) %>" class="space-y-4">
  <% response_drafts = conversation.response_drafts.includes(:bot_agent, :published_message, :response_reviews).order(:created_at, :id) %>

  <% if response_drafts.any? %>
    <% response_drafts.each do |draft| %>
      <section class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="text-sm font-semibold text-stone-950"><%= draft.category.presence || "Uncategorized" %></h3>
            <p class="mt-1 text-xs text-stone-500">Status: <%= draft.status.humanize %></p>
          </div>
          <span class="rounded-md bg-stone-100 px-2 py-1 text-xs font-semibold text-stone-700"><%= number_with_precision(draft.confidence, precision: 0) %>%</span>
        </div>

        <% if draft.review_reason.present? %>
          <p class="mt-3 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900"><%= draft.review_reason %></p>
        <% end %>

        <div class="mt-4 text-sm leading-6 text-stone-900"><%= simple_format(draft.body) %></div>

        <% if draft.published_message.present? %>
          <p class="mt-4 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">Published as message #<%= draft.published_message.position %>.</p>
        <% else %>
          <div class="mt-4 space-y-4">
            <%= button_to "Approve draft", approve_operator_response_draft_path(draft), method: :post, class: "w-full rounded-md bg-emerald-700 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>

            <%= form_with model: draft, url: publish_edit_operator_response_draft_path(draft), method: :post, class: "space-y-2" do |form| %>
              <%= form.label :body, "Edit and send", class: "text-sm font-medium text-stone-900" %>
              <%= form.text_area :body, value: draft.body, rows: 5, class: "block w-full resize-y rounded-md border border-stone-300 px-3 py-2 text-sm leading-6 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
              <%= form.submit "Send edited draft", class: "w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm font-semibold text-stone-900 shadow-sm hover:bg-stone-50" %>
            <% end %>

            <%= form_with model: draft, url: replace_operator_response_draft_path(draft), method: :post, class: "space-y-2" do |form| %>
              <%= form.label :body, "Replacement reply", class: "text-sm font-medium text-stone-900" %>
              <%= form.text_area :body, rows: 5, class: "block w-full resize-y rounded-md border border-stone-300 px-3 py-2 text-sm leading-6 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20", placeholder: "Write a replacement support reply" %>
              <%= form.submit "Reject and replace", class: "w-full rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold text-red-800 shadow-sm hover:bg-red-100" %>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  <% else %>
    <div class="rounded-lg border border-dashed border-stone-300 bg-white p-5 text-sm text-stone-600">No response drafts for this conversation.</div>
  <% end %>
</div>
