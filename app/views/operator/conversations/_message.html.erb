<article class="rounded-md border border-stone-200 bg-stone-50 p-4">
  <div class="flex flex-wrap items-center gap-2 text-xs text-stone-600">
    <span class="rounded bg-white px-2 py-1 font-semibold text-stone-900"><%= message.public_role %></span>
    <span><%= message.origin %></span>
    <% if message.author.present? %>
      <span>author: <%= message.author_type %>#<%= message.author_id %></span>
    <% end %>
    <% if message.published_by.present? %>
      <span>published by: <%= message.published_by_type %>#<%= message.published_by_id %></span>
    <% end %>
  </div>
  <div class="mt-3 text-sm leading-6 text-stone-900"><%= simple_format(message.body) %></div>
  <% if message.retrieval_results.any? %>
    <div class="mt-3 border-t border-stone-200 pt-3">
      <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Sources</p>
      <ul class="mt-1 space-y-1">
        <% message.retrieval_results.sort_by(&:rank).each do |result| %>
          <li class="text-xs text-stone-600">
            <span class="font-medium">#<%= result.rank %></span>
            <%= result.knowledge_document&.title || "Deleted document" %>
            <span class="text-stone-400">(score: <%= number_with_precision(result.score, precision: 2) %>)</span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if message.agent_decision_trace.present? %>
    <% trace = message.agent_decision_trace %>
    <% trace_metadata = trace.metadata_hash %>
    <div class="mt-3 border-t border-stone-200 pt-3">
      <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Agent decision trace</p>
      <dl class="mt-1 grid gap-1 text-xs text-stone-600 sm:grid-cols-2">
        <div>
          <dt class="font-medium text-stone-900">Outcome</dt>
          <dd><%= trace.outcome.humanize %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Provider</dt>
          <dd><%= [ trace.provider_name, trace.provider_model ].compact.join(" / ") %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Category</dt>
          <dd><%= trace.response_category.presence || "Uncategorized" %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Confidence</dt>
          <dd><%= trace.confidence.present? ? "#{number_with_precision(trace.confidence, precision: 0)}%" : "n/a" %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Review</dt>
          <dd><%= trace.review_required? ? trace.review_status.to_s.humanize : "Not required" %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Retrieved documents</dt>
          <dd><%= trace.retrieved_document_ids.presence&.join(", ") || "None" %></dd>
        </div>
        <% if trace.proposed_tools.any? %>
          <div>
            <dt class="font-medium text-stone-900">Tools</dt>
            <dd><%= trace.proposed_tools.join(", ") %></dd>
          </div>
        <% end %>
        <% if trace.proposed_actions.any? %>
          <div>
            <dt class="font-medium text-stone-900">Actions</dt>
            <dd><%= trace.proposed_actions.join(", ") %></dd>
          </div>
        <% end %>
        <% if trace_metadata["failure_reason"].present? %>
          <div>
            <dt class="font-medium text-stone-900">Fallback</dt>
            <dd><%= trace_metadata["failure_reason"] %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  <% end %>

  <% if message.feedbacks.any? %>
    <div class="mt-3 border-t border-stone-200 pt-3">
      <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Feedback</p>
      <ul class="mt-1 space-y-1">
        <% message.feedbacks.each do |feedback| %>
          <li class="text-xs text-stone-600">
            <span class="font-medium"><%= feedback.rating.humanize %></span>
            <% if feedback.note.present? %>
              <span class="text-stone-500">- <%= feedback.note %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if message.uploads.any? %>
    <div class="mt-3 border-t border-stone-200 pt-3">
      <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Uploads</p>
      <ul class="mt-1 space-y-1">
        <% message.uploads.each do |upload| %>
          <li class="text-xs text-stone-600">
            <span class="font-medium"><%= upload.file_type.humanize %></span>
            <span class="text-stone-400">(<%= upload.processing_status.humanize %>)</span>
            <% if upload.extracted_text.present? %>
              <span class="text-stone-500">- <%= upload.extracted_text %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</article>
