<div class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
  <h2 class="text-base font-semibold text-stone-950">Escalations</h2>

  <% if conversation.escalations.any? %>
    <ul class="mt-4 space-y-4">
      <% conversation.escalations.order(created_at: :desc).each do |escalation| %>
        <li class="rounded-md border border-amber-200 bg-amber-50 p-3">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-amber-950"><%= escalation.reason.humanize %></p>
              <p class="mt-1 text-sm text-amber-900"><%= escalation.summary %></p>
              <p class="mt-2 text-xs text-amber-800">Status: <%= escalation.status.humanize %></p>
            </div>
          </div>

          <%= form_with model: escalation, url: operator_escalation_path(escalation), method: :patch, class: "mt-3 flex items-center gap-2" do |form| %>
            <%= form.select :status, Escalation::STATUSES.map { |status| [ status.humanize, status ] }, {}, class: "block w-full rounded-md border border-amber-300 bg-white px-2 py-1 text-sm text-stone-900 shadow-sm" %>
            <%= form.submit "Update", class: "rounded-md bg-amber-700 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-amber-800" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-2 text-sm text-stone-600">No escalation is open for this conversation.</p>
  <% end %>
</div>
