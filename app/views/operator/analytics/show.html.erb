<% content_for :title, "Support analytics" %>

<section class="space-y-6">
  <div class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Operator workspace</p>
        <h1 class="mt-1 text-2xl font-semibold text-stone-950">Support analytics</h1>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Review queue", operator_conversations_path, class: "text-sm font-medium text-stone-600 hover:text-stone-950" %>
        <%= button_to "Sign out", operator_session_path, method: :delete, class: "text-sm font-medium text-stone-600 hover:text-stone-950" %>
      </div>
    </div>
  </div>

  <dl class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
      <dt class="text-sm font-medium text-stone-600">Total conversations</dt>
      <dd class="mt-2 text-3xl font-semibold text-stone-950"><%= @analytics.total_conversations %></dd>
    </div>
    <div class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
      <dt class="text-sm font-medium text-stone-600">Escalated conversations</dt>
      <dd class="mt-2 text-3xl font-semibold text-stone-950"><%= @analytics.escalated_conversations %></dd>
    </div>
    <div class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
      <dt class="text-sm font-medium text-stone-600">Escalation rate</dt>
      <dd class="mt-2 text-3xl font-semibold text-stone-950"><%= @analytics.escalation_rate.nil? ? "n/a" : number_to_percentage(@analytics.escalation_rate, precision: 1, strip_insignificant_zeros: true) %></dd>
    </div>
    <div class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
      <dt class="text-sm font-medium text-stone-600">Helpfulness rate</dt>
      <dd class="mt-2 text-3xl font-semibold text-stone-950"><%= @analytics.helpfulness_rate.nil? ? "n/a" : number_to_percentage(@analytics.helpfulness_rate, precision: 1, strip_insignificant_zeros: true) %></dd>
      <dd class="mt-1 text-xs text-stone-500"><%= pluralize(@analytics.feedback_responses, "rating") %></dd>
    </div>
  </dl>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_2fr]">
    <section class="overflow-hidden rounded-lg border border-stone-200 bg-white shadow-sm">
      <div class="border-b border-stone-200 px-5 py-4">
        <h2 class="text-base font-semibold text-stone-950">Top detected categories</h2>
      </div>
      <% if @analytics.top_categories.any? %>
        <ol class="divide-y divide-stone-200">
          <% @analytics.top_categories.each do |category, count| %>
            <li class="flex items-center justify-between gap-4 px-5 py-3 text-sm">
              <span class="font-medium text-stone-900"><%= category.humanize %></span>
              <span class="text-stone-600"><%= count %></span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="p-5 text-sm text-stone-600">No response categories recorded.</p>
      <% end %>
    </section>

    <section class="overflow-hidden rounded-lg border border-stone-200 bg-white shadow-sm">
      <div class="border-b border-stone-200 px-5 py-4">
        <h2 class="text-base font-semibold text-stone-950">Needs attention</h2>
      </div>
      <% if @analytics.attention_conversations.any? %>
        <ul class="divide-y divide-stone-200">
          <% @analytics.attention_conversations.each do |conversation| %>
            <% latest_draft = conversation.response_drafts.max_by(&:created_at) %>
            <% low_confidence_draft = conversation.response_drafts.select { |draft| draft.confidence < @analytics.confidence_threshold }.max_by(&:created_at) %>
            <% display_draft = low_confidence_draft || latest_draft %>
            <li>
              <%= link_to operator_conversation_path(conversation.public_id), class: "block px-5 py-4 hover:bg-stone-50" do %>
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-stone-950"><%= conversation.public_id %></p>
                    <div class="mt-2 flex flex-wrap gap-2">
                      <% unless conversation.closed? %>
                        <span class="rounded bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-900"><%= conversation.status.humanize %></span>
                      <% end %>
                      <% if low_confidence_draft.present? %>
                        <span class="rounded bg-red-100 px-2 py-1 text-xs font-semibold text-red-900">Low confidence</span>
                      <% end %>
                      <% if conversation.escalations.any? %>
                        <span class="rounded bg-sky-100 px-2 py-1 text-xs font-semibold text-sky-900">Escalated</span>
                      <% end %>
                    </div>
                  </div>
                  <dl class="grid grid-cols-2 gap-x-5 gap-y-1 text-xs text-stone-600 sm:text-right">
                    <div>
                      <dt class="font-medium text-stone-900">Confidence</dt>
                      <dd><%= display_draft ? number_to_percentage(display_draft.confidence, precision: 0) : "n/a" %></dd>
                    </div>
                    <div>
                      <dt class="font-medium text-stone-900">Category</dt>
                      <dd><%= display_draft&.category&.humanize || "n/a" %></dd>
                    </div>
                  </dl>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="p-5 text-sm text-stone-600">No unresolved or low-confidence conversations.</p>
      <% end %>
    </section>
  </div>
</section>
