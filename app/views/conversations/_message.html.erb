<% from_customer = message.customer? %>
<article id="<%= dom_id(message) %>" class="flex <%= from_customer ? "justify-end" : "justify-start" %>">
  <div class="max-w-[42rem] rounded-lg border px-4 py-3 shadow-sm <%= from_customer ? "border-emerald-200 bg-emerald-50" : "border-stone-200 bg-white" %>">
    <p class="text-xs font-semibold uppercase tracking-wide <%= from_customer ? "text-emerald-700" : "text-stone-500" %>">
      <%= from_customer ? "You" : "Support" %>
    </p>
    <div class="mt-1 text-sm leading-6 text-stone-900">
      <%= simple_format(message.body) %>
    </div>
    <% upload_request = message.response_draft if message == latest_support_message && message.response_draft&.upload_requested? %>
    <% if upload_request.present? %>
      <% requested_type_label = case upload_request.upload_type
         when "image" then "Image"
         when "document" then "Document"
         else "Image or document"
         end %>
      <% accepted_types = case upload_request.upload_type
         when "image" then Upload::IMAGE_CONTENT_TYPES.join(",")
         when "document" then Upload::DOCUMENT_CONTENT_TYPES.join(",")
         else Upload::ALLOWED_CONTENT_TYPES.join(",")
         end %>
      <% completed_upload = message.uploads.order(created_at: :desc).detect { |upload| upload.file.attached? } %>
      <div class="mt-4 border-t border-stone-200 pt-4">
        <% if completed_upload.present? %>
          <div class="rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-900">
            <p class="font-semibold">Upload received</p>
            <p class="mt-1 break-all text-xs"><%= completed_upload.file.filename %></p>
          </div>
        <% else %>
          <p class="text-sm font-semibold text-stone-950">Upload requested</p>
          <p class="mt-1 text-xs text-stone-600">Requested file: <%= requested_type_label %></p>
          <%= form_with scope: :upload, url: conversation_message_uploads_path(message.conversation.public_id, message), multipart: true, class: "mt-3 space-y-3" do |form| %>
            <%= form.label :file, "Choose #{requested_type_label.downcase}", class: "sr-only" %>
            <%= form.file_field :file, accept: accepted_types, required: true, class: "block w-full text-xs text-stone-700 file:mr-3 file:rounded-md file:border-0 file:bg-stone-100 file:px-3 file:py-2 file:text-xs file:font-semibold file:text-stone-800 hover:file:bg-stone-200" %>
            <%= form.submit "Upload file", class: "rounded-md bg-stone-950 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-stone-800" %>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <% if message.support? %>
      <% feedback = message.feedbacks.first %>
      <div class="mt-4 border-t border-stone-100 pt-3">
        <%= form_with scope: :feedback, url: conversation_message_feedback_path(message.conversation.public_id, message), class: "space-y-2" do |form| %>
          <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Was this helpful?</p>
          <div class="flex flex-wrap gap-2">
            <%= form.button "Helpful", name: "feedback[rating]", value: "helpful", class: "rounded-md border px-3 py-1.5 text-xs font-semibold #{feedback&.rating == "helpful" ? "border-emerald-600 bg-emerald-50 text-emerald-800" : "border-stone-300 bg-white text-stone-700 hover:border-emerald-500"}" %>
            <%= form.button "Not helpful", name: "feedback[rating]", value: "not_helpful", class: "rounded-md border px-3 py-1.5 text-xs font-semibold #{feedback&.rating == "not_helpful" ? "border-amber-600 bg-amber-50 text-amber-800" : "border-stone-300 bg-white text-stone-700 hover:border-amber-500"}" %>
          </div>
          <%= form.label :note, "Optional note", class: "sr-only" %>
          <%= form.text_field :note, value: feedback&.note, maxlength: 500, placeholder: "Optional note", class: "block w-full rounded-md border border-stone-300 px-3 py-1.5 text-xs text-stone-900 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
          <% if feedback&.persisted? %>
            <p class="text-xs text-stone-500">Feedback saved.</p>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</article>
