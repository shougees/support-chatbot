.DS_Store
*.log
tmp/
log/
.env
.env.*
!.env.example
storage/
node_modules/
vendor/bundle/
.bundle/
.kamal/secrets*

# Ignore key files for decrypting credentials and more.
/config/*.key

/app/assets/builds/*
!/app/assets/builds/.keep

# Generated Roast workflow artifacts; keep the directory but not its outputs.
/.roast/out/*
!/.roast/out/.gitkeep
