{
  "name": "support-chatbot",
  "dockerComposeFile": [
    "compose.yaml",
    "compose-agent.yaml"
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/support-chatbot",
  "shutdownAction": "stopCompose",
  "overrideCommand": true,
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Rails",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "KoichiSasada.vscode-rdbg",
        "GitHub.vscode-github-actions"
      ]
    }
  }
}
