{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResponseUnitCandidate",
  "description": "Schema for a pluggable chatbot response unit candidate produced by the Roast build_response_units workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "type",
    "priority",
    "summary",
    "trigger",
    "response_contract",
    "guardrails",
    "acceptance_criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$",
      "description": "Stable identifier in '<type>.<slug>' form."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "type": {
      "type": "string",
      "enum": ["clarifying_question", "upload_request", "escalation"]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "trigger": {
      "type": "object",
      "minProperties": 1
    },
    "response_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "answer_text",
        "confidence",
        "category",
        "source_references",
        "upload_requested",
        "upload_type",
        "escalation_recommended",
        "escalation_reason"
      ],
      "properties": {
        "answer_text": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "category": { "type": "string", "minLength": 1 },
        "source_references": {
          "type": "array",
          "items": { "type": "string" }
        },
        "upload_requested": { "type": "boolean" },
        "upload_type": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "enum": ["image", "document", "any"] }
          ]
        },
        "escalation_recommended": { "type": "boolean" },
        "escalation_reason": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
