# Copy this file to .env for local development.
# Never commit real API keys.

# fake keeps local chatbot behavior deterministic.
# openai sends bot responses through OpenAI's Responses API.
# openai_compatible sends bot responses through a chat-completions provider
# such as Fireworks AI or Kimi/Moonshot.
SUPPORT_BOT_PROVIDER=fake

# Required only when SUPPORT_BOT_PROVIDER=openai.
OPENAI_API_KEY=

# Required only when SUPPORT_BOT_PROVIDER=openai_compatible.
# Fireworks example:
# LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_MODEL=accounts/fireworks/models/kimi-k2.6
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
