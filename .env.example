# Copy this file to .env for local development.
# Never commit real API keys.

# Both real providers go through one unified LLM layer
# (SupportBot::LlmProvider) that speaks the OpenAI-compatible chat-completions
# wire format and supports tool calling. They differ only in default endpoint
# and credentials.
#
# fake               keeps local chatbot behavior deterministic (no network).
# openai             chat completions against api.openai.com.
# fireworks          chat completions against api.fireworks.ai (recommended).
# openai_compatible  chat completions against any compatible base URL
#                    (generic fallback; use fireworks for Fireworks AI).
SUPPORT_BOT_PROVIDER=fake

# Required only when SUPPORT_BOT_PROVIDER=openai.
OPENAI_API_KEY=
# Optional override of the OpenAI base URL (defaults to https://api.openai.com/v1).
# OPENAI_BASE_URL=

# Required only when SUPPORT_BOT_PROVIDER=fireworks.
# FIREWORKS_BASE_URL defaults to https://api.fireworks.ai/inference/v1.
# FIREWORKS_MODEL defaults to accounts/fireworks/models/kimi-k2.6.
FIREWORKS_API_KEY=
# FIREWORKS_BASE_URL=
# FIREWORKS_MODEL=

# Required only when SUPPORT_BOT_PROVIDER=openai_compatible.
# LLM_* vars are also accepted by the fireworks provider as fallbacks.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
